generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model ConsentLog {
  id            Int      @id @default(autoincrement())
  walletAddress String
  ipAddress     String
  countryCode   String
  userAgent     String
  agreedToTerms Boolean  @default(true)
  timestamp     DateTime @default(now())
}

model ICOSettings {
  id             Int      @id @default(1)
  phaseName      String   @default("Phase 1: Seed Round")
  phaseTargetUSD Float    @default(5000000.0) // $5 Million default
  isActive       Boolean  @default(true)
  phaseEndDate   DateTime?

  // NEW: Referral Config
  referralActive Boolean  @default(false)
  referralPercent Float   @default(5.0) // e.g. 5%
}

// NEW TABLE Referal
model Referral {
  id             Int      @id @default(autoincrement())
  referrer       String   // Who sent the link
  referee        String   // Who bought
  purchaseAmount Float    // In USD/USDT
  referrerReward Float    // <--- Renamed from rewardEIT
  refereeBonus   Float    // <--- NEW: Extra tokens for the buyer
  txHash         String   @unique // Proof of purchase
  status         String   @default("PENDING") // PENDING, PAID, REJECTED
  timestamp      DateTime @default(now())
}

//Here we store person's details to whom we allocated the vesting tokens.
model VestingEntry {
  id        Int      @id @default(autoincrement())
  address   String   // The Wallet Address
  name      String   // Employee Name
  role      String   // FOUNDER, TEAM, PARTNER
  category  String?  // KOL, Marketing Agency, etc.
  note      String?  // Extra info
  crypto    String?  // ETH, USDT, USDC
  amount    Float    // Amount in EIT
  amountUSD Float?   // USD Value at time of purchase
  eitPrice  Float?   // EIT Price in USD
  phase     String?  // Calculation Phase
  country   String?  // Investor Country
  kycStatus String?  // "Yes" or "No" for compliance
  txHash    String   // Blockchain Proof
  isRevoked Boolean  @default(false)
  createdAt DateTime @default(now())
}

// ActivityLog for Admin - enterprise edition
model ActivityLog {
  id        Int      @id @default(autoincrement())
  admin     String   // Wallet address
  action    String   // e.g. "PAUSE_SALE"
  details   String?  // Optional context
  severity  String   @default("INFO") // INFO | WARNING | CRITICAL
  ipAddress String?  // Admin's public IP at time of action
  location  String?  // Geo-location (country/city)
  txHash    String?  // Blockchain transaction hash (for on-chain actions)
  timestamp DateTime @default(now())
}

// NEW: Isolate Public Sales from manual Vesting/HR
model PublicSale {
  id             Int      @id @default(autoincrement())
  address        String   // Buyer address
  name           String   @default("Public Investor")
  role           String   // PUBLIC_KYC or PUBLIC_OPEN
  amount         Float    // Amount in EIT
  amountUSD      Float?   // USD Value
  eitPrice       Float?   // Price per EIT
  txHash         String   @unique
  phase          String?
  country        String?
  crypto         String?  // ETH, USDT, USDC
  timestamp      DateTime @default(now())
  note           String?
}