generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model ConsentLog {
  id            Int      @id @default(autoincrement())
  walletAddress String
  ipAddress     String
  countryCode   String
  userAgent     String
  agreedToTerms Boolean  @default(true)
  timestamp     DateTime @default(now())
}

model ICOSettings {
  id              Int       @id @default(autoincrement())
  phaseName       String    @default("Phase 1: Seed Round")
  phaseTargetUSD  Float     @default(5000000.0)
  isActive        Boolean   @default(true)
  referralActive  Boolean   @default(false)
  referralPercent Float     @default(5.0)
  phaseEndDate    DateTime?
}

model Referral {
  id             Int      @id @default(autoincrement())
  referrer       String
  referee        String
  purchaseAmount Float
  referrerReward Float
  refereeBonus   Float
  txHash         String   @unique
  status         String   @default("PENDING")
  timestamp      DateTime @default(now())
}

model VestingEntry {
  id        Int      @id @default(autoincrement())
  address   String
  name      String
  role      String
  category  String?
  note      String?
  crypto    String?
  amount    Float
  amountUSD Float?
  eitPrice  Float?
  phase     String?
  country   String?
  txHash    String
  isRevoked Boolean   @default(false)
  revokedAt DateTime?
  createdAt DateTime  @default(now())
  kycStatus String?
}

model ActivityLog {
  id        Int      @id @default(autoincrement())
  admin     String
  action    String
  details   String?
  severity  String   @default("INFO")
  ipAddress String?
  location  String?
  txHash    String?
  timestamp DateTime @default(now())

  @@index([timestamp])
  @@index([severity])
  @@index([admin])
  @@index([action])
  @@index([severity, timestamp])
}

model ActivityLogArchive {
  id            Int      @id @default(autoincrement())
  originalLogId Int?
  admin         String
  action        String
  details       String?
  severity      String   @default("INFO")
  ipAddress     String?
  location      String?
  txHash        String?
  timestamp     DateTime
  archivedAt    DateTime @default(now())
  archiveReason String   @default("RETENTION")

  @@index([originalLogId])
  @@index([timestamp])
  @@index([archivedAt])
  @@index([severity])
  @@index([action])
}

model KycVerification {
  id                 Int       @id @default(autoincrement())
  walletAddress      String    @unique
  provider           String
  credentialHash     String
  verificationMethod String    @default("decentralized_identity")
  status             String    @default("VERIFIED_PENDING_WHITELIST")
  verifiedAt         DateTime  @default(now())
  approvedAt         DateTime?
  approvedBy         String?
  lastError          String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@index([provider])
  @@index([status])
  @@index([verifiedAt])
}

model PublicSale {
  id        Int      @id @default(autoincrement())
  address   String
  name      String   @default("Public Investor")
  role      String
  amount    Float
  amountUSD Float?
  eitPrice  Float?
  txHash    String   @unique
  phase     String?
  country   String?
  crypto    String?
  timestamp DateTime @default(now())
  note      String?
}

model BurnLog {
  id             Int      @id @default(autoincrement())
  type           String
  totalAmount    Float
  burnedAmount   Float
  recycledAmount Float    @default(0)
  region         String?
  batchRef       String?
  reason         String?
  txHash         String   @unique
  admin          String
  timestamp      DateTime @default(now())

  @@index([type])
  @@index([timestamp])
}
